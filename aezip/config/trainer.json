{
    "Dataset": {
        "shuffle": true,
        "batch_size": 64,
        "split": {
            "random_split": true,
            "train_prop": 0.9,
            "val_prop": 0.1
        }
    },
    "Trainer": {
        "max_epochs": 1,
        "enable_checkpointing": false,
        "callbacks": {"metrics": ["EarlyStopping"]}
    },
    "disable_sandbox": true
}
